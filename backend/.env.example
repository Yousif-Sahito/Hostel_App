# Backend Environment Variables

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (Required)
DATABASE_URL="mysql://user:password@localhost:3306/hostel_mess"

# JWT Configuration (Required - Change in production!)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Admin Credentials (Set strong password in production!)
ADMIN_EMAIL="admin@hostel.com"
ADMIN_PASSWORD="admin123"

# Firebase Configuration (Optional - Only if using notifications)
# Get this from Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"your-project-id",...}'

# Logging
LOG_LEVEL=info
