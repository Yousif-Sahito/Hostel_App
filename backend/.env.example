# Backend Environment Variables

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (Required)
DATABASE_URL="mysql://user:password@localhost:3306/hostel_mess"

# JWT Configuration (Required - Change in production!)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Admin Credentials (Set strong password in production!)
ADMIN_EMAIL="a**n@h**el.com"
ADMIN_PASSWORD="a***3"

# Firebase Configuration (Optional - Only if using notifications)
# Get this from Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"your-project-id",...}'

# Password Reset + Email (Required for forgot-password emails)
FRONTEND_URL="http://localhost:56725/#"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@example.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Hostel Mess <no-reply@hostelmess.com>"
# Email verification link also uses FRONTEND_URL and routes to /verify-email

# Logging
LOG_LEVEL=info

# Allowed frontend origins (comma separated)
# Example: CORS_ORIGIN="https://app.example.com,https://admin.example.com"
CORS_ORIGIN="http://localhost:56725,http://127.0.0.1:56725"
